{
  "tasks": {
    "dev": "deno run -A npm:vite",
    "build": "deno run -A npm:vite build",
    "preview": "deno run -A npm:vite preview",
    "tauri:dev": "deno run -A npm:@tauri-apps/cli tauri dev",
    "tauri:build": "deno run -A npm:@tauri-apps/cli tauri build",
    "rrs:compile": "deno run --allow-read --allow-write tools/rrs/cli.ts",
    "rrs:decompile": "deno run --allow-read --allow-write tools/rrs/decompile.ts",
    "rrs:roundtrip": "deno run --allow-read --allow-write --allow-run tools/rrs/batch_roundtrip.ts",
    "rpy2rrs": "deno run --allow-read --allow-write tools/rrs/rpy2rrs.ts"
  },
  "nodeModulesDir": "auto",
  "imports": {
    "@tauri-apps/api/core": "npm:@tauri-apps/api/core",
    "@tauri-apps/plugin-dialog": "npm:@tauri-apps/plugin-dialog",
    "@tauri-apps/plugin-fs": "npm:@tauri-apps/plugin-fs"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true
  }
}
